{
  "compilerOptions": {
    /* Estructura */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Entorno */
    "module": "commonjs",
    "target": "es2019",
    "lib": ["es2019"],
    "types": ["node"],

    /* Interoperabilidad */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* Calidad */
    "strict": true,
    "skipLibCheck": true,

    /* Debug */
    "sourceMap": true
  }
}