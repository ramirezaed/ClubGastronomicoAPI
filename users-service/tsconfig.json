{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@domain/*": ["src/modules/users/domain/*"],
      "@application/*": ["src/modules/users/application/*"],
      "@infra/*": ["src/modules/users/infrastructure/*"]
    },

    "ignoreDeprecations": "5.0",

    "module": "commonjs",
    "target": "es2019",
    "lib": ["es2019"],
    "types": ["node"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true
  }
}